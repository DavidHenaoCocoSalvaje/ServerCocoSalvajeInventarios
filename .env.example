# Ejemplo de variables de entorno para Azure Container Apps
# Copia este archivo como .env.example y configura estos valores en Azure

# === Configuración de Base de Datos ===
# Configura estos valores en Azure Container Apps Environment Variables
DB_HOST=tu-servidor-postgresql.postgres.database.azure.com
DB_PORT=5432
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña_segura
DB_NAME=inventarios_cosal

# === Configuración de Seguridad ===
# Genera una clave secreta fuerte para JWT
SECRET_KEY=tu_clave_secreta_muy_segura_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Configuración Regional ===
LOCAL_TIMEZONE=America/Bogota

# === Configuración de Shopify (si aplica) ===
SHOP_SHOPIFY=tu-tienda.myshopify.com
SHOP_VERSION=2025-07
API_KEY_SHOPIFY=tu_api_key_de_shopify

# === Variables adicionales para Azure ===
# Estas se configuran automáticamente en Azure Container Apps
PORT=8000
PYTHONPATH=/app
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
